# Browser key for the Google Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional runtime fallback for Vercel/server environments.
GOOGLE_MAPS_API_KEY=

# Moment import admin tool.
MOMENT_ADMIN_PASSWORD=
OPENAI_API_KEY=

# Optional image generation overrides. Defaults are suitable for GPT Image.
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_RESEARCH_MODEL=gpt-5-mini
OPENAI_ENABLE_VISUAL_RESEARCH=true
